// Prisma schema for Care — `auth` and `app` PostgreSQL schemas
// Run: pnpm --filter @care/api db:migrate:dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "app"]
}

// ── Auth schema ─────────────────────────────────────────────────────────────

enum OAuthProvider {
  google
  apple
  github

  @@schema("auth")
}

model OAuthIdentity {
  id         String        @id @default(cuid())
  userId     String        @map("user_id")
  provider   OAuthProvider
  providerId String        @map("provider_id")
  email      String?
  linkedAt   DateTime      @default(now()) @map("linked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("oauth_identities")
  @@schema("auth")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  deviceId  String?   @map("device_id")
  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
  @@schema("auth")
}

// ── App schema ───────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  phone        String?  @unique
  name         String
  avatarUrl    String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  oauthIdentities OAuthIdentity[]
  refreshTokens   RefreshToken[]
  deviceTokens    DeviceToken[]
  memberships     CircleMember[]
  assignedTasks   Task[]         @relation("AssignedTasks")
  completedTasks  Task[]         @relation("CompletedTasks")
  slotCompletions TaskSlotCompletion[] @relation("SlotCompleter")
  chatMessages    ChatMessage[]
  chatThreadReads ChatThreadRead[]
  aiSuggestions   AiSuggestedAction[]

  @@map("User")
  @@schema("app")
}

enum DevicePlatform {
  ios
  android

  @@schema("app")
}

model DeviceToken {
  id        String         @id @default(cuid())
  userId    String         @map("user_id")
  token     String
  platform  DevicePlatform
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@map("device_tokens")
  @@schema("app")
}

model Circle {
  id          String   @id @default(cuid())
  name        String
  description String?
  heartName   String
  heartAvatar String?
  /// UI accent (hex), e.g. #6B8F71
  color       String   @default("#6B8F71")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      CircleMember[]
  plans        Plan[]
  concerns     Concern[]
  tasks        Task[]
  chatThreads  ChatThread[]
  schedules    Schedule[]
  invites      CircleInvite[]
  aiSuggestions AiSuggestedAction[]

  @@map("Circle")
  @@schema("app")
}

model CircleMember {
  id       String   @id @default(cuid())
  circleId String
  userId   String
  role     String
  joinedAt DateTime @default(now())

  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([circleId, userId])
  @@map("CircleMember")
  @@schema("app")
}

model Plan {
  id          String   @id @default(cuid())
  circleId    String
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  circle   Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  tasks    Task[]
  concerns Concern[]

  @@map("Plan")
  @@schema("app")
}

model Concern {
  id          String    @id @default(cuid())
  circleId    String
  planId      String?
  title       String
  description String?
  dueAt       DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  circle Circle  @relation(fields: [circleId], references: [id], onDelete: Cascade)
  plan   Plan?   @relation(fields: [planId], references: [id])
  tasks  Task[]

  @@map("Concern")
  @@schema("app")
}

model Task {
  id                String    @id @default(cuid())
  circleId          String
  planId            String?
  concernId         String?
  title             String
  description       String?
  assignedToUserId  String?
  status            String    @default("pending")
  dueAt             DateTime?
  completedAt       DateTime?
  completedByUserId String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  /// When true, completions are tracked per day + slot in TaskSlotCompletion (e.g. feed 2× daily).
  isRecurring         Boolean  @default(false)
  /// JSON string[] of "HH:mm" times in circle-local interpretation (e.g. ["08:00","17:00"]).
  recurrenceSlotTimes Json?

  circle          Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  plan            Plan?  @relation(fields: [planId], references: [id])
  concern         Concern? @relation(fields: [concernId], references: [id])
  assignedTo      User?  @relation("AssignedTasks", fields: [assignedToUserId], references: [id])
  completedBy     User?  @relation("CompletedTasks", fields: [completedByUserId], references: [id])
  slotCompletions TaskSlotCompletion[]

  @@map("Task")
  @@schema("app")
}

model TaskSlotCompletion {
  id                String   @id @default(cuid())
  taskId            String
  date              DateTime @db.Date
  slotIndex         Int
  completedAt       DateTime @default(now())
  completedByUserId String

  task        Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completedBy User @relation("SlotCompleter", fields: [completedByUserId], references: [id])

  @@unique([taskId, date, slotIndex])
  @@map("TaskSlotCompletion")
  @@schema("app")
}

model ChatThread {
  id        String   @id @default(cuid())
  circleId  String
  title     String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  circle   Circle            @relation(fields: [circleId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
  reads    ChatThreadRead[]

  @@map("ChatThread")
  @@schema("app")
}

/// Per-user read cursor for a thread (messages at or before lastReadAt count as seen).
model ChatThreadRead {
  id         String   @id @default(cuid())
  userId     String
  threadId   String
  lastReadAt DateTime

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
  @@index([userId])
  @@map("ChatThreadRead")
  @@schema("app")
}

model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  userId    String
  body      String
  createdAt DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id])

  @@index([threadId, createdAt])
  @@map("ChatMessage")
  @@schema("app")
}

model Schedule {
  id          String    @id @default(cuid())
  circleId    String
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@map("Schedule")
  @@schema("app")
}

enum InviteKind {
  link
  direct_email
  direct_phone

  @@schema("app")
}

model CircleInvite {
  id               String     @id @default(cuid())
  circleId         String
  secretCode       String     @unique
  inviterUserId    String
  kind             InviteKind
  invitedEmail     String?
  invitedPhone     String?
  expiresAt        DateTime?
  consumedAt       DateTime?
  consumedByUserId String?
  createdAt        DateTime   @default(now())

  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@index([circleId])
  @@map("CircleInvite")
  @@schema("app")
}

model AiSuggestedAction {
  id         String    @id @default(cuid())
  circleId   String
  userId     String
  threadId   String?
  payload    Json
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@map("AiSuggestedAction")
  @@schema("app")
}
