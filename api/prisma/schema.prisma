// Prisma schema for Care
// Run: pnpm --filter @care/api db:migrate:dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth ──────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  email       String?  @unique
  phone       String?  @unique
  name        String
  avatarUrl   String?
  passwordHash String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authProviders OAuthAccount[]
  memberships   CircleMember[]
  assignedTasks Task[]         @relation("AssignedTasks")
  completedTasks Task[]        @relation("CompletedTasks")
}

model OAuthAccount {
  id             String @id @default(cuid())
  userId         String
  provider       String  // "google" | "apple"
  providerUserId String
  accessToken    String?
  refreshToken   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([provider, userId]) // one account per provider per user
}

// ── Care Circles ──────────────────────────────────────────────────────────────

model Circle {
  id           String @id @default(cuid())
  name         String
  description  String?
  heartName    String  // The person/pet being cared for
  heartAvatar  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members  CircleMember[]
  plans    Plan[]
  concerns Concern[]
  tasks    Task[]
}

model CircleMember {
  id        String   @id @default(cuid())
  circleId  String
  userId    String
  role      String   // "organizer" | "caregiver" | "supporter" | "care_recipient" | "professional"
  joinedAt  DateTime @default(now())

  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([circleId, userId])
}

// ── Plans, Concerns, Tasks ────────────────────────────────────────────────────

model Plan {
  id          String   @id @default(cuid())
  circleId    String
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  circle   Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  tasks    Task[]
  concerns Concern[]
}

model Concern {
  id          String    @id @default(cuid())
  circleId    String
  planId      String?
  title       String
  description String?
  dueAt       DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  circle Circle  @relation(fields: [circleId], references: [id], onDelete: Cascade)
  plan   Plan?   @relation(fields: [planId], references: [id])
  tasks  Task[]
}

model Task {
  id                 String    @id @default(cuid())
  circleId           String
  planId             String?
  concernId          String?
  title              String
  description        String?
  assignedToUserId   String?
  status             String    @default("pending") // "pending" | "in_progress" | "completed" | "skipped"
  dueAt              DateTime?
  completedAt        DateTime?
  completedByUserId  String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  circle      Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  plan        Plan?    @relation(fields: [planId], references: [id])
  concern     Concern? @relation(fields: [concernId], references: [id])
  assignedTo  User?    @relation("AssignedTasks", fields: [assignedToUserId], references: [id])
  completedBy User?    @relation("CompletedTasks", fields: [completedByUserId], references: [id])
}
