{
  "name": "care",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "ios": "pnpm --filter @care/app ios",
    "ship:api": "op run --env-file=.env -- railway up --service api",
    "ship:web": "op run --env-file=.env -- railway up --service web",
    "ship": "pnpm ship:api && pnpm ship:web"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "patchedDependencies": {
      "react-native-onesignal": "patches/react-native-onesignal.patch"
    }
  }
}
