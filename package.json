{
  "name": "care",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "ios": "pnpm --filter @care/app ios",
    "ship:api": "pnpm --filter @care/shared build && pnpm --filter @care/api type-check && op run --env-file=.env -- railway up --service api --detach",
    "ship:web": "pnpm --filter @care/web type-check && op run --env-file=.env -- railway up --service web --detach",
    "ship": "pnpm ship:api && pnpm ship:web"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "react": "19.2.0",
      "react-dom": "19.2.4",
      "react-native": "0.83.4",
      "react-native-worklets": "0.7.4"
    }
  }
}
