# 1Password Service Account Key — used by `op run` to inject secrets
# Get from 1Password: op://care/service-account/credential
SERVICE_ACCOUNT_KEY=

# Root `pnpm dev`, `pnpm dev:api`, `pnpm dev:app`, `pnpm dev:web`, and `pnpm ios` load this file via dotenv-cli.
# You can still use: op run --env-file=.env -- pnpm dev
#
# ── Injected at runtime via `op run --env-file=.env -- <command>` ──
# op://care/railway/project_id
RAILWAY_PROJECT_ID=

# Auto-injected by Railway
#RAILWAY_PUBLIC_DOMAIN=

# op://care/railway/token_prod
RAILWAY_TOKEN=

# op://care/expo/id
EXPO_PROJECT_ID=

# op://care/api/jwt_secret
JWT_SECRET=

# op://care/database/url
DATABASE_URL=

# Public web origin for invite links in emails (no trailing slash), e.g. https://care.example.com
WEB_PUBLIC_URL=

# Postmark (API): transactional email for circle invites
POSTMARK_TOKEN=
POSTMARK_FROM_EMAIL=

# OpenAI (API): Tend assistant — optional model override
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Google Sign-In (API) — Web application client in Google Cloud Console ─────────
# Authorized redirect URI must be exactly: {public API base}/auth/google/callback
# e.g. https://mac-studio….ts.net/auth/google/callback (Tailscale funnel) or Railway URL.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Public base URL of the API (no trailing slash). Use this for Tailscale/ngrok/local HTTPS
# when RAILWAY_PUBLIC_DOMAIN is unset. OAuth redirect_uri = API_PUBLIC_URL + /auth/google/callback
# API_PUBLIC_URL=https://mac-studio.tail28832a.ts.net

# Hostname only (Railway sets this automatically). Ignored if API_PUBLIC_URL is set.
# RAILWAY_PUBLIC_DOMAIN=

# Must match the native app deep-link scheme (e.g. fformcare → fformcare://oauth/google).
OAUTH_APP_REDIRECT_SCHEME=fformcare

# op://care/apple/app_id  (Bundle ID, e.g. com.care.app)
APPLE_APP_ID=

# op://care/apple/team_id  (10-char Apple Developer Team ID)
APPLE_TEAM_ID=

# op://care/apple/auth_key  (.p8 key file content — used by API for web OAuth)
APPLE_AUTH_KEY=

# op://care/apple/app_store_connect_id  (Key ID — used for both .p8 auth key and App Store Connect API)
APPLE_KEY_ID=

# op://care/apple/app_store_connect_key  (.p8 key — used for Sign in with Apple server-side + EAS)
APP_STORE_CONNECT_KEY=
