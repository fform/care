# Automatically loads your 1Password service account token into the shell
# so any `op run` call in any script works without manual setup.
#
# One-time setup:
#   brew install direnv
#   echo 'eval "$(direnv hook zsh)"' >> ~/.zshrc && source ~/.zshrc
#   direnv allow   ← run once in this directory

if [ ! -f .env ]; then
  echo "⚠️  No .env file. Copy .env.example → .env and set SERVICE_ACCOUNT_KEY."
  return
fi

token=$(grep ^SERVICE_ACCOUNT_KEY .env | cut -d= -f2 | tr -d '[:space:]')

if [ -z "$token" ]; then
  echo "⚠️  SERVICE_ACCOUNT_KEY is empty in .env"
  return
fi

export OP_SERVICE_ACCOUNT_TOKEN="$token"
