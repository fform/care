# Server-side fetch to Care API (invite landing page). No CORS needed.
# Must be the same API/database your app uses to create invites, or links 404.
# If unset, the invite page defaults to https://care-api.up.railway.app (see web/app/invite/[code]/page.tsx).
API_URL=https://care-api.up.railway.app

# Optional: browser-visible API origin (defaults with API_URL above are enough for SSR)
NEXT_PUBLIC_API_URL=

NEXT_PUBLIC_APP_SCHEME=fformcare
NEXT_PUBLIC_IOS_APP_STORE_URL=https://apps.apple.com/app/idYOUR_ID
NEXT_PUBLIC_ANDROID_PLAY_URL=https://play.google.com/store/apps/details?id=com.fform.care
