{
  "name": "@care/app",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "codegenConfig": {
    "name": "CareApp",
    "type": "all",
    "jsSrcsDir": "."
  },
  "scripts": {
    "dev": "op run --env-file=../.env -- expo start",
    "android": "op run --env-file=../.env -- expo run:android",
    "ios": "op run --env-file=../.env -- expo run:ios",
    "ios:prebuild:sim": "EXPO_IOS_SIMULATOR_NO_APPLE_SIGNIN=1 op run --env-file=../.env -- expo prebuild --platform ios",
    "web": "op run --env-file=../.env -- expo start --web",
    "build:ios": "op run --env-file=../.env -- eas build --platform ios",
    "build:android": "op run --env-file=../.env -- eas build --platform android",
    "build:preview": "op run --env-file=../.env -- eas build --profile preview",
    "build:local:ios": "op run --env-file=../.env -- eas build --platform ios --local",
    "build:local:android": "op run --env-file=../.env -- eas build --platform android --local",
    "build:local:preview:ios": "op run --env-file=../.env -- eas build --platform ios --profile preview --local",
    "build:local:preview:android": "op run --env-file=../.env -- eas build --platform android --profile preview --local",
    "update": "op run --env-file=../.env -- eas update",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@care/shared": "workspace:*",
    "@expo-google-fonts/open-sans": "^0.2.3",
    "expo": "~52.0.0",
    "expo-apple-authentication": "~7.1.0",
    "expo-build-properties": "~0.13.0",
    "expo-auth-session": "~6.0.0",
    "expo-constants": "~17.0.0",
    "expo-crypto": "~14.0.0",
    "expo-font": "~13.0.0",
    "expo-linking": "~7.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "expo-web-browser": "~14.0.0",
    "moti": "^0.30.0",
    "onesignal-expo-plugin": "^2.4.0",
    "phosphor-react-native": "^2.1.1",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-onesignal": "^5.2.6",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.0",
    "typescript": "^5.7.0"
  }
}
