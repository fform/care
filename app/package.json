{
  "name": "@care/app",
  "version": "0.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:simulator": "expo run:ios --device",
    "web": "expo start --web",
    "build:local:ios:submit": "eas build --platform ios --local --non-interactive --output ./dist/app.ipa && eas submit -p ios --path ./dist/app.ipa --profile production",
    "build:ios": "eas build --platform ios --auto-submit",
    "build:android": "eas build --platform android --auto-submit",
    "build:preview": "eas build --profile preview",
    "build:local:ios": "eas build --platform ios --local",
    "build:local:android": "eas build --platform android --local",
    "build:local:preview:ios": "eas build --platform ios --profile preview --local",
    "build:local:preview:android": "eas build --platform android --profile preview --local",
    "update": "eas update",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "maestro:test": "maestro test maestro/flows",
    "maestro:studio": "maestro studio"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@care/shared": "workspace:*",
    "@expo-google-fonts/open-sans": "^0.2.3",
    "@expo/config-plugins": "55.0.7",
    "@expo/metro-runtime": "~55.0.7",
    "@expo/ui": "~55.0.10",
    "expo": "~55.0.9",
    "expo-apple-authentication": "~55.0.9",
    "expo-audio": "~55.0.13",
    "expo-auth-session": "~55.0.10",
    "expo-build-properties": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.9",
    "expo-notifications": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "^55.0.16",
    "expo-web-browser": "~55.0.10",
    "lucide-react-native": "^1.7.0",
    "moti": "^0.30.0",
    "phosphor-react-native": "^2.1.1",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.2.14",
    "eas-cli": "^16.28.0",
    "typescript": "^5.7.0"
  }
}
