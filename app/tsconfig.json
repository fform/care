{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@care/shared": [
        "../shared/src/index.ts"
      ],
      "@care/shared/*": [
        "../shared/src/*"
      ],
      "@/*": [
        "./src/*"
      ],
      "moti/build/components/view": [
        "./node_modules/moti/build/components/view"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
