# Copy to `.env` and fill in. Restart Expo after changes.
# Only `EXPO_PUBLIC_*` keys are available in JS at runtime (embedded at bundle time).
#
# Runtime: this app targets a **custom dev build / EAS build**, not the Expo Go client.
# Use `expo start --dev-client` with your development build installed (see app.config.ts).

# ── API ────────────────────────────────────────────────────────────────────────
# Defaults to production URL in `config.ts` if unset.
# EXPO_PUBLIC_API_URL=https://care-api.up.railway.app

# ── Google Sign-In (native OAuth → auth code sent to API) ─────────────────────
# Must match the OAuth client in Google Cloud and the API’s GOOGLE_OAUTH_CLIENT_ID.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Optional if unset: iOS URL scheme is derived from the client id and merged into app `scheme`.
# Set explicitly only if you use a non-standard scheme.
# EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_URL_SCHEME=

# ── Push notifications (expo-notifications / device token registration) ───────
# EAS project UUID; also set EXPO_PROJECT_ID below for `app.config` / updates URL.
EXPO_PUBLIC_EAS_PROJECT_ID=

# ── EAS / Expo (build & OTA — not bundled as EXPO_PUBLIC unless you reference them in JS) ──
EXPO_PROJECT_ID=
APPLE_TEAM_ID=

# ── Local development ───────────────────────────────────────────────────────────
# Set to `1` to skip Apple Sign In entitlement during `expo prebuild` on simulator (see plugin).
# EXPO_IOS_SIMULATOR_NO_APPLE_SIGNIN=1
