# Copy to `.env` and fill in. Restart Expo after changes.
# Only `EXPO_PUBLIC_*` keys are available in JS at runtime (embedded at bundle time).

EXPO_PUBLIC_EAS_PROJECT_ID=
EXPO_PROJECT_ID=
APPLE_TEAM_ID=

# API base URL (no trailing slash). Google Sign-In opens GET {this}/auth/google in the browser.
# EXPO_PUBLIC_API_URL=https://care-api.up.railway.app

# Deep-link scheme; must match `scheme` in app.config and API `OAUTH_APP_REDIRECT_SCHEME`.
# EXPO_PUBLIC_APP_URL_SCHEME=fformcare

EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=a
EXPO_PUBLIC_GOOGLE_ANDROID_URL_SCHEME=ab
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=c
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=d